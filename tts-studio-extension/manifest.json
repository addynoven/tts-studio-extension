{
  "manifest_version": 3,
  "name": "TTS Studio",
  "version": "1.0.0",
  "description": "Browser TTS with KittenTTS, Kokoro & Piper — 100% local, no server",
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "offscreen"
  ],

  "web_accessible_resources": [
    {
      "resources": ["lib/*", "models/*", "models/**/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "TTS Studio"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
