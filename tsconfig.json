{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "allowJs": true,
    "checkJs": false,
    "types": ["chrome", "vitest/globals", "node"],
    "noEmit": true
  },
  "include": ["src/**/*.ts", "src/**/*.js", "test/**/*.ts", "test/**/*.js", "vite.config.ts", "vitest.config.ts"],
  "exclude": ["node_modules", "dist", "tts-studio-extension"]
}
